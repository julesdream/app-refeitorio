generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRoles {
  SERVIDOR
  ALUNO
}

enum MealTypes {
  CAFE
  ALMOCO
  JANTAR
}

model User {
  id    Int       @id @default(autoincrement())
  name  String
  email String    @unique
  password String
  role UserRoles @default(ALUNO)
}

model Menu {
  id Int @id @default(autoincrement())
  date DateTime @db.Date @unique
  meals Meal[]
}

model Meal {
  menuId Int
  type MealTypes

  menu Menu @relation(fields: [menuId], references: [id], onDelete: Cascade)
  items MealItem[]

  @@id([menuId, type])
}

model MealItem {
  id Int @id @default(autoincrement())
  
  menuId Int
  mealType MealTypes

  foodId Int
  food Food @relation(fields: [foodId], references: [id])

  meal Meal @relation(fields: [menuId, mealType], references: [menuId, type], onDelete: Cascade)

  @@unique([menuId, mealType, foodId])
}

model Food {
  id Int @id @default(autoincrement())
  name String

  mealItems MealItem[]
}